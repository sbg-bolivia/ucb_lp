# Copia este archivo a `.env` y completa los valores.
# Nunca subas `.env` al repositorio.

# --- Base de datos (local: docker-compose en puerto 5435) ---
DATABASE_URL="postgresql://dev:dev123@localhost:5435/miapp_dev"

# --- Sitio (producción: https://sbgbo.com) ---
SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Auth (Better Auth) ---
# Genera uno: openssl rand -base64 32
BETTER_AUTH_SECRET="cambiar-en-produccion"

# Google OAuth (opcional en dev si solo usas email/password)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Email (Nodemailer / SES SMTP en producción) ---
NODEMAILER_SMTP=""
NODEMAILER_PORT="587"
NODEMAILER_USER=""
NODEMAILER_PASSWORD=""

# --- Build Amplify / CI (evita validar secrets en compile) ---
# SKIP_ENV_VALIDATION="true"

# --- S3 (futuro: subida de banners e imágenes desde admin) ---
# AWS_REGION="us-east-1"
# AWS_S3_BUCKET=""
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
