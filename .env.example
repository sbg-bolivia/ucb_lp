# Copia este archivo a `.env` y completa los valores.
# Nunca subas `.env` al repositorio.

# --- Base de datos ---
# RDS (desarrollo/producción):
# DATABASE_URL="postgresql://USER:PASS@endpoint.rds.amazonaws.com:5432/sbgbo_prod?sslmode=require"
# Local con Docker (usa: pnpm dev:local):
# DATABASE_URL="postgresql://dev:dev123@localhost:5435/miapp_dev"
DATABASE_URL="postgresql://dev:dev123@localhost:5435/miapp_dev"

# --- Sitio (producción: https://sbgbo.com) ---
# Deben coincidir con el puerto donde corre `pnpm dev` (PORT o -p).
SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Auth (Better Auth) ---
# Genera uno: openssl rand -base64 32
BETTER_AUTH_SECRET="cambiar-en-produccion"

# Google OAuth (opcional en dev si solo usas email/password)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Email (Nodemailer / SES SMTP en producción) ---
NODEMAILER_SMTP=""
NODEMAILER_PORT="587"
NODEMAILER_USER=""
NODEMAILER_PASSWORD=""

# --- Build Amplify / CI (evita validar secrets en compile) ---
# SKIP_ENV_VALIDATION="true"

# --- S3 (imágenes del admin: eventos, banners, equipo…) ---
# Amplify NO acepta variables que empiecen con AWS_ — usa S3_* en la consola.
S3_REGION="us-east-1"
S3_BUCKET="sbgbo-assets"
# Local/dev: credenciales IAM con s3:PutObject en el bucket
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# En Amplify deja las claves vacías y asigna permisos S3 al rol del servicio.
# Opcional: CloudFront u otra URL pública base (sin barra final)
# S3_PUBLIC_URL_BASE="https://cdn.sbgbo.com"
#
# Compatibilidad local (opcional, no usar en Amplify):
# AWS_REGION="us-east-1"
# AWS_S3_BUCKET="sbgbo-assets"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
