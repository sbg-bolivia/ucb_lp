generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

generator zod {
  provider         = "prisma-zod-generator"
  output           = "../src/lib/zod"
  createInputTypes = true
  writeNullish     = false
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id              String       @id @default(uuid())
  name            String       @default("My App")
  displayName     String       @default("My Application")
  description     String?
  email           String?
  phone           String?
  address         String?
  city            String?
  country         String?
  website         String?
  facebookUrl     String?
  twitterUrl      String?
  instagramUrl    String?
  linkedinUrl     String?
  youtubeUrl      String?
  meetupUrl       String?
  whatsappUrl     String?
  tiktokUrl       String?
  foundedYear     Int?
  logoUrl         String?
  faviconUrl      String?
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  termsUrl        String?
  privacyUrl      String?
  cookiesUrl      String?
  complaintsUrl   String?
  /// Legacy JSON — migrar a CoreTeamMember cuando el admin esté listo
  coreTeam        Json?
  tagline         String?
  mission         String?      @db.Text
  vision          String?      @db.Text
  heroVideoUrl    String?
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  users           User[]
  permissions     Permission[]
  roles           Role[]
  translations    Translation[]
  clubEvents       ClubEvent[]
  clubProjects     ClubProject[]
  siteBanners      SiteBanner[]
  coreTeamMembers  CoreTeamMember[]
  awsCommunities   AwsCommunity[]
  awsServices      AwsService[]
  auditLogs        AuditLog[]

  @@map("tenants")
}

/// Visitas a páginas públicas (métricas del dashboard).
model PageViewHit {
  id         String   @id @default(cuid())
  path       String   @db.VarChar(500)
  referrer   String?  @db.VarChar(500)
  deviceType String?  @db.VarChar(20)
  tenantId   String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@map("page_view_hits")
}

/// Acciones registradas en el panel admin (solo usuarios autenticados del core team).
model AuditLog {
  id         String      @id @default(cuid())
  tenantId   String?
  tenant     Tenant?     @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userEmail  String
  userName   String?
  action     AuditAction
  resource   String      @db.VarChar(80)
  resourceId String?     @db.VarChar(80)
  summary    String      @db.VarChar(500)
  changes    Json?
  ipAddress  String?     @db.VarChar(45)
  userAgent  String?     @db.VarChar(500)
  procedure  String?     @db.VarChar(200)
  createdAt  DateTime    @default(now())

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([resource, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@map("audit_logs")
}

/// Eventos del club (sitio público /eventos); CRUD manual desde el dashboard.
model ClubEvent {
  id               String             @id @default(uuid())
  tenantId         String
  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title            String
  description      String?            @db.Text
  startsAt         DateTime?
  endsAt           DateTime?
  location         String?
  /// Banner principal (S3 o URL externa)
  imageUrl         String?
  /// @deprecated Usar registrationUrl — se mantiene por compatibilidad
  externalUrl      String?
  registrationUrl  String?
  registrationType RegistrationType   @default(EXTERNAL)
  source           EventSource        @default(MANUAL)
  status           EventStatus        @default(UPCOMING)
  isOnline         Boolean            @default(false)
  attendeeCount    Int?
  promoVideoUrl    String?
  /// Afiche / flyer para eventos ya realizados
  pastFlyerUrl     String?
  /// Fotos y videos del evento: [{ "url": "...", "type": "image"|"video" }]
  recapGallery     Json?
  isFeatured       Boolean            @default(false)
  /// Para sync Meetup futuro (requiere Meetup Pro)
  meetupEventId    String?            @unique
  lastSyncedAt     DateTime?
  isPublished      Boolean            @default(true)
  /// workshop | talk | certification | networking — si es null, se infiere del título
  category         String?
  sortOrder        Int                @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  collaborations   EventCollaboration[]
  versions         ClubEventVersion[]

  @@index([tenantId])
  @@index([tenantId, isPublished, startsAt])
  @@index([tenantId, status, startsAt])
  @@map("club_events")
}

/// Snapshot de un evento antes de cada actualización (historial / restaurar)
model ClubEventVersion {
  id            String    @id @default(uuid())
  eventId       String
  event         ClubEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  versionNumber Int
  snapshot      Json
  changedById   String?
  changeNote    String?
  createdAt     DateTime  @default(now())

  @@index([eventId, versionNumber(sort: Desc)])
  @@map("club_event_versions")
}

/// Colaboración de un evento con otra comunidad AWS (SBG, User Group, etc.)
model EventCollaboration {
  id          String        @id @default(uuid())
  eventId     String
  communityId String
  event       ClubEvent     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  community   AwsCommunity  @relation(fields: [communityId], references: [id], onDelete: Cascade)
  note        String?
  createdAt   DateTime      @default(now())

  @@unique([eventId, communityId])
  @@index([communityId])
  @@map("event_collaborations")
}

/// Otras comunidades AWS en Bolivia (SBG, User Groups por departamento, Cloud Clubs…)
model AwsCommunity {
  id           String               @id @default(uuid())
  tenantId     String
  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  communityType AwsCommunityType    @default(USER_GROUP)
  university   String?
  department   String?
  city         String
  country      String               @default("BO")
  latitude     Float?
  longitude    Float?
  description  String?              @db.Text
  meetupUrl    String?
  websiteUrl   String?
  logoUrl      String?
  isOwnGroup   Boolean              @default(false)
  isPublished  Boolean              @default(true)
  sortOrder    Int                  @default(0)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  collaborations EventCollaboration[]

  @@index([tenantId, isPublished, sortOrder])
  @@index([tenantId, city])
  @@map("aws_communities")
}

/// Banners promocionales del home / secciones
model SiteBanner {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String?
  subtitle    String?
  imageUrl    String
  linkUrl     String?
  placement   BannerPlacement @default(HOME_HERO)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, isActive, placement])
  @@map("site_banners")
}

/// Core team normalizado (reemplaza Tenant.coreTeam JSON)
model CoreTeamMember {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  role         String
  bio          String?  @db.Text
  photoUrl     String?
  linkedinUrl  String?
  instagramUrl String?
  githubUrl    String?
  email        String?
  badgeLabel   String?
  isPublished  Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId, isPublished, sortOrder])
  @@map("core_team_members")
}

/// Catálogo de servicios AWS (/servicios) — contenido curado por el core team
model AwsService {
  id                   String            @id @default(uuid())
  tenantId             String
  tenant               Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  slug                 String
  name                 String
  category             AwsServiceCategory @default(COMPUTE)
  shortDescription     String
  technicalExplanation String?           @db.Text
  whenToUse            String?           @db.Text
  whenNotToUse         String?           @db.Text
  officialDocsUrl      String?
  iconUrl              String?
  coverImageUrl        String?
  promoVideoUrl        String?
  /// Links extra [{ "title": "...", "url": "...", "type": "docs|blog|lab" }]
  resources            Json?
  popularityScore      Int?
  difficultyLevel      AwsDifficultyLevel?
  pricingNote          String?           @db.Text
  isPopular            Boolean           @default(false)
  isPublished          Boolean           @default(false)
  sortOrder            Int               @default(0)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  cards                AwsServiceCard[]

  @@unique([tenantId, slug])
  @@index([tenantId, isPublished, category])
  @@map("aws_services")
}

/// Tarjetas opcionales extra por servicio (casos de uso, tips, labs, advertencias…)
model AwsServiceCard {
  id          String           @id @default(uuid())
  serviceId   String
  service     AwsService       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  cardType    AwsServiceCardType @default(USE_CASE)
  title       String?
  content     String           @db.Text
  iconKey     String?
  linkUrl     String?
  linkLabel   String?
  isPublished Boolean          @default(true)
  sortOrder   Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([serviceId, isPublished, sortOrder])
  @@map("aws_service_cards")
}

/// Proyectos del club — ocultos por feature flag; CRUD desde el dashboard.
model ClubProject {
  id           String    @id @default(uuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title        String
  description  String?   @db.Text
  tags         String?
  imageUrl     String?
  projectUrl   String?
  isPublished  Boolean   @default(true)
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, isPublished, sortOrder])
  @@map("club_projects")
}

model User {
  id            String     @id @default(cuid())
  name          String
  email         String     @unique
  emailVerified Boolean    @default(false)
  image         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  phone         String?
  language      Language   @default(ES)
  theme         Theme      @default(AUTO)
  tenantId      String?
  accounts      Account[]
  sessions      Session[]
  tenant        Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles     UserRole[]
  auditLogs     AuditLog[]

  @@index([tenantId])
  @@index([email, tenantId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
}

model Role {
  id              String           @id @default(uuid())
  name            String
  displayName     String
  description     String?
  isActive        Boolean          @default(true)
  isSystem        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  tenantId        String
  rolePermissions RolePermission[]
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles       UserRole[]

  @@unique([name, tenantId])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id              String             @id @default(uuid())
  action          PermissionAction
  resource        PermissionResource
  description     String?
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  tenantId        String
  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]

  @@unique([action, resource, tenantId])
  @@index([tenantId])
  @@map("permissions")
}

model UserRole {
  id         String    @id @default(uuid())
  userId     String
  roleId     String
  assignedAt DateTime  @default(now())
  assignedBy String?
  expiresAt  DateTime?
  role       Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@index([expiresAt])
  @@map("user_roles")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

enum Language {
  ES
  EN
  PT
}

enum Theme {
  LIGHT
  DARK
  AUTO
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  REORDER
  LOGIN
  LOGOUT
  OTHER
}

enum PermissionAction {
  CREATE
  READ
  UPDATE
  DELETE
  MANAGE
}

enum PermissionResource {
  USER
  ROLE
  PERMISSION
  DASHBOARD
  ADMIN
  CONTENT
}

// ================================
// i18n MODELS
// ================================

model Locale {
  id            String       @id @default(uuid())
  languageCode  String       @unique // ISO 639-1: 'es', 'en', 'pt', 'fr'
  name          String       // "Spanish", "English"
  nativeName    String       // "Español", "English"
  locale        String?      // 'es_ES', 'en_US', 'pt_BR'
  direction     String       @default("ltr") // 'ltr' or 'rtl'
  currencySymbol String?
  isActive      Boolean      @default(true)
  isDefault     Boolean      @default(false) // Solo uno puede ser true
  flagUrl       String?
  displayOrder  Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  translations  Translation[]

  @@index([languageCode])
  @@index([isActive])
  @@map("locales")
}

model Translation {
  id                String            @id @default(uuid())
  
  // Entidad traducida (polimórfico)
  translatableType  String            // 'course', 'category', 'chapter', etc.
  translatableId    String            // UUID de la entidad
  
  // Idioma
  localeId         String
  locale           Locale            @relation(fields: [localeId], references: [id], onDelete: Cascade)
  
  // Campo traducido
  fieldName        String            // 'title', 'description', etc.
  translatedValue  String            @db.Text
  
  // Estado de traducción
  translationStatus TranslationStatus @default(DRAFT)
  translatorNotes  String?           @db.Text
  approvedBy       String?           // User ID que aprobó
  approvedAt       DateTime?
  
  // Multi-tenant support (opcional - si las traducciones son por tenant)
  tenantId         String?
  tenant           Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // Una traducción única por (entidad, idioma, campo, tenant)
  @@unique([translatableType, translatableId, localeId, fieldName, tenantId])
  @@index([translatableType, translatableId, localeId])
  @@index([localeId])
  @@index([translationStatus])
  @@index([tenantId])
  @@map("translations")
}

enum TranslationStatus {
  DRAFT
  REVIEW
  APPROVED
  PUBLISHED
}

// ================================
// CLUB CONTENT ENUMS
// ================================

enum EventSource {
  MANUAL
  MEETUP
  COLLABORATION
}

enum EventStatus {
  DRAFT
  UPCOMING
  PAST
  CANCELLED
}

enum RegistrationType {
  MEETUP
  YOUTUBE
  GOOGLE_MEET
  ZOOM
  TEAMS
  EXTERNAL
  NONE
}

enum AwsCommunityType {
  STUDENT_BUILDER_GROUP
  USER_GROUP
  CLOUD_CLUB
  COMMUNITY_DAY
  OTHER
}

enum BannerPlacement {
  HOME_HERO
  HOME_SECONDARY
  EVENTS_PAGE
  SERVICES_PAGE
}

enum AwsServiceCategory {
  COMPUTE
  STORAGE
  DATABASE
  NETWORKING
  SECURITY
  ANALYTICS
  MACHINE_LEARNING
  INTEGRATION
  MANAGEMENT
  OTHER
}

enum AwsServiceCardType {
  USE_CASE
  TIP
  WARNING
  LAB
  PRICING
  ARCHITECTURE
  RELATED_LINK
  CUSTOM
}

enum AwsDifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}
